// CREAR UN PROGRAMA QUE CALCULE EL AREA Y EL PERIMETRO DE UNA CIRCUNFERENCIA  A PARTIR DE SU DIAMETRO
PROCESO AREAYPERIMETRO
  ESCRIBIR "PROGRAMA QUE CALCULA EL AREA Y PERIMETRO DE UNA CIRCUNFERENCIA"
  ESCRIBIR "."
  ESCRIBIR "."
  ESCRIBIR "."
  ESCRIBIR "DIGITE EL DIAMETRO DE LA CIRCUNFERENCIA"
  LEER DIAMETRO
  RADIO = DIAMETRO /2 
  AREA = 3.1416 * RADIO * RADIO
  PERIMETRO = 2 * 3.1416 * RADIO
  ESCRIBIR "EL CIRCULO DE DIAMETRO ",DIAMETRO," TIENE UN RADIO DE ", RADIO, " DONDE SU AREA ES IGUAL A ", AREA, " Y SU PERIMETRO ES IGUAL A ",PERIMETRO
FINPROCESO
